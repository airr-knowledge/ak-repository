[Unit]
Description=AIRR Knowledge web services
Documentation=https://github.com/airr-knowledge/ak-repository
After=ak-db.service
Requires=ak-db.service

[Service]
Restart=always
ExecStart=docker compose -f /mnt/data1/akadmin/ak-repository/docker-compose/ak-web/docker-compose.yml up
ExecStop=docker compose -f /mnt/data1/akadmin/ak-repository/docker-compose/ak-web/docker-compose.yml down

[Install]
WantedBy=multi-user.target
